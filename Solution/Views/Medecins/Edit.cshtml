                    </td>
                    <td><input class="form-control" name="Adresses[${adresseIndex}].AdresseLigne1" type="text" /></td>
                    <td><input class="form-control" name="Adresses[${adresseIndex}].Ville" type="text" /></td>
                    <td><input class="form-control" name="Adresses[${adresseIndex}].Province" type="text" /></td>
                    <td><input class="form-control" name="Adresses[${adresseIndex}].CodePostal" type="text" /></td>
                    <td class="text-center">
                        <input name="Adresses[${adresseIndex}].EstPrincipale" type="checkbox" value="true" />
