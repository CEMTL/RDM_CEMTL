                        </button>
                    </td>
                </tr>`;

            $("#tableInstallations tbody").append(html);
            installationIndex++;
            reparserValidation();
        });

        $("#btnAddUnite").on("click", function () {
            var html = `
                <tr>
                    <td style="display:none;">
                        <input type="hidden" name="UnitesOrganisationnelles[${uniteIndex}].MedecinUniteOrganisationnelleId" value="0" />
                    </td>
                    <td>
                        <select class="form-control" name="UnitesOrganisationnelles[${uniteIndex}].UniteOrganisationnelleId">
                            <option value="">-- Sélectionner --</option>
                            ${uniteOptions}
                        </select>
                    </td>
                    <td>
                        <input class="form-control" name="UnitesOrganisationnelles[${uniteIndex}].RangSource" type="text" />
                    </td>
                    <td>
                        <input class="form-control" name="UnitesOrganisationnelles[${uniteIndex}].DateDebut" type="date" />
                    </td>
                    <td>
                        <input class="form-control" name="UnitesOrganisationnelles[${uniteIndex}].DateFin" type="date" />
