                    <td>
                        <input class="form-control" name="NominationsAdministratives[${nominationIndex}].DateFin" type="date" />
                    </td>
                    <td class="text-center">
                        <input name="NominationsAdministratives[${nominationIndex}].EstActive" type="checkbox" value="true" />
                        <input name="NominationsAdministratives[${nominationIndex}].EstActive" type="hidden" value="false" />
                    </td>
                    <td class="text-center">
                        <input class="js-remove-flag" name="NominationsAdministratives[${nominationIndex}].Supprimer" type="checkbox" value="true" />
                        <input name="NominationsAdministratives[${nominationIndex}].Supprimer" type="hidden" value="false" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-danger btn-sm js-remove-row">
                            <i class="fa fa-times"></i>
