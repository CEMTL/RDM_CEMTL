                    <td class="text-center">
                        <input class="js-remove-flag" name="UnitesOrganisationnelles[${uniteIndex}].Supprimer" type="checkbox" value="true" />
                        <input name="UnitesOrganisationnelles[${uniteIndex}].Supprimer" type="hidden" value="false" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-danger btn-sm js-remove-row">
                            <i class="fa fa-times"></i>
                        </button>
                    </td>
                </tr>`;

            $("#tableUnites tbody").append(html);
            uniteIndex++;
            reparserValidation();
        });

        $("#btnAddNomination").on("click", function () {
            var html = `
                <tr>
                    <td style="display:none;">
                        <input type="hidden" name="NominationsAdministratives[${nominationIndex}].NominationAdministrativeId" value="0" />
                    </td>
                    <td>
                        <select class="form-control" name="NominationsAdministratives[${nominationIndex}].NominationId">
                            <option value="">-- Sélectionner --</option>
                            ${nominationOptions}
                        </select>
                    </td>
                    <td>
                        <select class="form-control" name="NominationsAdministratives[${nominationIndex}].TypeNominationId">
                            <option value="">-- Sélectionner --</option>
