                    </td>
                    <td class="text-center">
                        <input class="js-remove-flag" name="Adresses[${adresseIndex}].Supprimer" type="checkbox" value="true" />
                        <input name="Adresses[${adresseIndex}].Supprimer" type="hidden" value="false" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-danger btn-sm js-remove-row">
                            <i class="fa fa-times"></i>
                        </button>
                    </td>
                </tr>`;

            $("#tableAdresses tbody").append(html);
            adresseIndex++;
            reparserValidation();
        });

        $("#btnAddInstallation").on("click", function () {
            var html = `
                <tr>
                    <td style="display:none;">
                        <input type="hidden" name="Installations[${installationIndex}].MedecinInstallationId" value="0" />
                    </td>
                    <td>
                        <select class="form-control" name="Installations[${installationIndex}].InstallationId">
                            <option value="">-- Sélectionner --</option>
                            ${installationOptions}
                        </select>
                    </td>
                    <td>
                        <input class="form-control" name="Installations[${installationIndex}].RangInstallation" type="text" value="1" />
                    </td>
                    <td class="text-center">
                        <input name="Installations[${installationIndex}].EstPrincipale" type="checkbox" value="true" />
                        <input name="Installations[${installationIndex}].EstPrincipale" type="hidden" value="false" />
                    </td>
                    <td>
                        <input class="form-control" name="Installations[${installationIndex}].DateDebut" type="date" />
                    </td>
                    <td>
                        <input class="form-control" name="Installations[${installationIndex}].DateFin" type="date" />
                    </td>
                    <td class="text-center">
                        <input class="js-remove-flag" name="Installations[${installationIndex}].Supprimer" type="checkbox" value="true" />
                        <input name="Installations[${installationIndex}].Supprimer" type="hidden" value="false" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-danger btn-sm js-remove-row">
