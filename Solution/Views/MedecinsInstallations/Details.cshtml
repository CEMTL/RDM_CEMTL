@model Solution.ViewModels.MedecinsInstallations.MedecinInstallationDetailsViewModel
@{
    ViewBag.Title = "Détails MedecinInstallation";
}

<div class="page-header-custom">
    <h2>Détails MedecinInstallation</h2>
</div>

<div class="dashboard-card">
    <dl class="dl-horizontal">
        <dt>Médecin</dt>
        <dd>@Model.MedecinLibelle</dd>
        <dt>Installation</dt>
        <dd>@Model.InstallationLibelle</dd>
        <dt>Rang</dt>
        <dd>@Model.RangInstallation</dd>
        <dt>Date début</dt>
        <dd>@(Model.DateDebut.HasValue ? Model.DateDebut.Value.ToString("yyyy-MM-dd") : "-")</dd>
        <dt>Date fin</dt>
        <dd>@(Model.DateFin.HasValue ? Model.DateFin.Value.ToString("yyyy-MM-dd") : "-")</dd>
        <dt>Principale</dt>
        <dd>@(Model.EstPrincipale ? "Oui" : "Non")</dd>
    </dl>
</div>

<div class="dashboard-card actions-card">
    <a href="@Url.Action("Edit", new { id = Model.MedecinInstallationId })" class="btn btn-warning btn-icon-only" title="Modifier"><i class="fa-solid fa-pen-to-square"></i></a>
    <a href="@Url.Action("Index")" class="btn btn-default btn-icon-only" title="Retour"><i class="fa-solid fa-arrow-left"></i></a>
</div>