@model Solution.ViewModels.UnitesOrganisationnelles.UniteOrganisationnelleFormViewModel

<div class="dashboard-card">
    <div class="form-group">
        @Html.LabelFor(m => m.Libelle)
        @Html.TextBoxFor(m => m.Libelle, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Libelle, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.TypeUnite)
        @Html.TextBoxFor(m => m.TypeUnite, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.TypeUnite, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.UniteParentId)
        @Html.DropDownListFor(m => m.UniteParentId, Model.UniteParentIdOptions, "-- Sélectionner --", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.UniteParentId, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        <div class="checkbox"><label>@Html.CheckBoxFor(m => m.EstActif) Actif</label></div>
        @Html.ValidationMessageFor(m => m.EstActif, "", new { @class = "text-danger" })
    </div>
</div>