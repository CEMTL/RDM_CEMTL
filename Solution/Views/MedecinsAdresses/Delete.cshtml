@model Solution.ViewModels.MedecinsAdresses.MedecinAdresseDetailsViewModel
@{
    ViewBag.Title = "Supprimer MedecinAdresse";
}

<div class="page-header-custom">
    <h2>Supprimer MedecinAdresse</h2>
</div>

<div class="dashboard-card">
    <p>Confirmez-vous la suppression de cet enregistrement ?</p>
    <dl class="dl-horizontal">
        <dt>Médecin</dt>
        <dd>@Model.MedecinLibelle</dd>
        <dt>Adresse</dt>
        <dd>@Model.AdresseLigne1</dd>
        <dt>Ville</dt>
        <dd>@Model.Ville</dd>
        <dt>Province</dt>
        <dd>@Model.Province</dd>
        <dt>Code postal</dt>
        <dd>@Model.CodePostal</dd>
        <dt>Principale</dt>
        <dd>@(Model.EstPrincipale ? "Oui" : "Non")</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger btn-icon-only" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
        <a href="@Url.Action("Index")" class="btn btn-default btn-icon-only" title="Annuler"><i class="fa-solid fa-xmark"></i></a>
    }
</div>