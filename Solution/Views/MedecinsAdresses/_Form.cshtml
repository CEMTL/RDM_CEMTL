@model Solution.ViewModels.MedecinsAdresses.MedecinAdresseFormViewModel

<div class="dashboard-card">
    <div class="form-group">
        @Html.LabelFor(m => m.MedecinId)
        @Html.DropDownListFor(m => m.MedecinId, Model.MedecinIdOptions, "-- Sélectionner --", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.MedecinId, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.AdresseLigne1)
        @Html.TextBoxFor(m => m.AdresseLigne1, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.AdresseLigne1, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Ville)
        @Html.TextBoxFor(m => m.Ville, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Ville, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Province)
        @Html.TextBoxFor(m => m.Province, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Province, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.CodePostal)
        @Html.TextBoxFor(m => m.CodePostal, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.CodePostal, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        <div class="checkbox"><label>@Html.CheckBoxFor(m => m.EstPrincipale) Principale</label></div>
        @Html.ValidationMessageFor(m => m.EstPrincipale, "", new { @class = "text-danger" })
    </div>
</div>