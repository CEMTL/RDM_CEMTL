@model Solution.ViewModels.DossiersPrivilegeDecision.DossierPrivilegeDecisionDetailsViewModel
@{
    ViewBag.Title = "Supprimer DossierPrivilegeDecision";
}

<div class="page-header-custom">
    <h2>Supprimer DossierPrivilegeDecision</h2>
</div>

<div class="dashboard-card">
    <p>Confirmez-vous la suppression de cet enregistrement ?</p>
    <dl class="dl-horizontal">
        <dt>Dossier</dt>
        <dd>@Model.DossierPrivilegeLibelle</dd>
        <dt>Instance</dt>
        <dd>@Model.InstanceDecisionLibelle</dd>
        <dt>Texte décision</dt>
        <dd>@Model.TexteDecision</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger btn-icon-only" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
        <a href="@Url.Action("Index")" class="btn btn-default btn-icon-only" title="Annuler"><i class="fa-solid fa-xmark"></i></a>
    }
</div>