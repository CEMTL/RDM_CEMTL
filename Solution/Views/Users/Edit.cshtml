@model Solution.ViewModels.UserEditViewModel
@using Microsoft.AspNet.Identity

@{
    ViewBag.Title = "Modifier l'utilisateur";

    var currentUserId = User.Identity.GetUserId();
    var isSelf = string.Equals(Model.Id, currentUserId, System.StringComparison.OrdinalIgnoreCase);
    var estCompteAdmin = string.Equals((Model.UserName ?? "").Trim(), "Admin", System.StringComparison.OrdinalIgnoreCase);
}

<div class="page-header">
    <h2>Modifier — @Model.Nom @Model.Prenom</h2>
</div>

@using (Html.BeginForm("Edit", "Users", FormMethod.Post, new { @class = "form-horizontal" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Id)

    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    <div class="form-group">
        @Html.LabelFor(m => m.Nom, new { @class = "col-sm-3 control-label" })
        <div class="col-sm-6">
            @Html.TextBoxFor(m => m.Nom, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Nom, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Prenom, new { @class = "col-sm-3 control-label" })
        <div class="col-sm-6">
            @Html.TextBoxFor(m => m.Prenom, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Prenom, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Email, new { @class = "col-sm-3 control-label" })
        <div class="col-sm-6">
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.UserName, new { @class = "col-sm-3 control-label" })
        <div class="col-sm-6">
            @if (estCompteAdmin)
            {
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", @readonly = "readonly" })
                <span class="help-block text-muted">
                    Le nom d'utilisateur du compte Admin est protégé.
                </span>
            }
            else
            {
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control" })
            }

            @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.PhoneNumber, new { @class = "col-sm-3 control-label" })
        <div class="col-sm-6">
            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "514-555-1234" })
            @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        <label class="col-sm-3 control-label">Rôles</label>
        <div class="col-sm-6">
            @if (Model.RolesDisponibles != null && Model.RolesDisponibles.Any())
            {
                foreach (var r in Model.RolesDisponibles)
                {
                    var estRoleAdmin =
                        string.Equals(r.Text, "Admin", System.StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(r.Value, "Admin", System.StringComparison.OrdinalIgnoreCase);

                    var disableRole =
                        estCompteAdmin ||                 // le compte Admin garde ses rôles inchangés
                        (isSelf && estRoleAdmin);        // on ne peut pas retirer son propre rôle Admin

                    <div class="checkbox">
                        <label>
                            <input type="checkbox"
                                   name="RolesSelectionnes"
                                   value="@r.Value"
                                   @(r.Selected ? "checked=\"checked\"" : "")
                                   @(disableRole ? "disabled=\"disabled\"" : "") />
                            @r.Text
                        </label>
                    </div>

                    if (disableRole && r.Selected)
                    {
                        <input type="hidden" name="RolesSelectionnes" value="@r.Value" />
                    }
                }

                if (estCompteAdmin)
                {
                    <p class="help-block text-muted">
                        Les rôles du compte Admin sont protégés et ne peuvent pas être modifiés.
                    </p>
                }
            }
            else
            {
                <p class="text-muted">
                    Aucun rôle dans AspNetRoles.
                    @Html.ActionLink("En créer un", "Create", "Roles")
                </p>
            }
        </div>
    </div>

    <div class="form-group">
        <div class="col-sm-offset-3 col-sm-9">
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}