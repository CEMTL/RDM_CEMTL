@* AspNetUserRoles — cases à cocher *@
<div class="form-group">
    <label class="col-sm-3 control-label">
        Rôles <small class="text-muted">(AspNetUserRoles)</small>
    </label>
    <div class="col-sm-6">
        @foreach (var r in Model.RolesDisponibles)
        {
            <div class="checkbox">
                <label>
                    <input type="checkbox" name="RolesSelectionnes" value="@r.Value"
                           @(r.Selected ? "checked" : "") />
                    @r.Text
                </label>
            </div>
        }
        @if (!Model.RolesDisponibles.Any())
        {
            <p class="text-muted">
                Aucun rôle dans AspNetRoles.
                @Html.ActionLink("En créer un", "Create", "Roles")
            </p>
        }
    </div>
</div>
