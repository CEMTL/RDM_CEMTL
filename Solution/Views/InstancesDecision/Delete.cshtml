@model Solution.ViewModels.InstancesDecision.InstanceDecisionDetailsViewModel
@{
    ViewBag.Title = "Supprimer InstanceDecision";
}

<div class="page-header-custom">
    <h2>Supprimer InstanceDecision</h2>
</div>

<div class="dashboard-card">
    <p>Confirmez-vous la suppression de cet enregistrement ?</p>
    <dl class="dl-horizontal">
        <dt>Type instance</dt>
        <dd>@Model.TypeInstanceDecisionLibelle</dd>
        <dt>Code instance</dt>
        <dd>@Model.CodeInstance</dd>
        <dt>Date instance</dt>
        <dd>@(Model.DateInstance.HasValue ? Model.DateInstance.Value.ToString("yyyy-MM-dd") : "-")</dd>
        <dt>Libellé instance</dt>
        <dd>@Model.LibelleInstance</dd>
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger btn-icon-only" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
        <a href="@Url.Action("Index")" class="btn btn-default btn-icon-only" title="Annuler"><i class="fa-solid fa-xmark"></i></a>
    }
</div>