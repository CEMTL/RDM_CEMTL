@model Solution.ViewModels.EntentesFDC.EntenteFDCFormViewModel

<div class="dashboard-card">
    <div class="form-group">
        @Html.LabelFor(m => m.MedecinId)
        @Html.DropDownListFor(m => m.MedecinId, Model.MedecinIdOptions, "-- Sélectionner --", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.MedecinId, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.TypeEntenteFDC)
        @Html.TextBoxFor(m => m.TypeEntenteFDC, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.TypeEntenteFDC, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.DateAdhesion)
        @Html.TextBoxFor(m => m.DateAdhesion, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        @Html.ValidationMessageFor(m => m.DateAdhesion, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.DateFin)
        @Html.TextBoxFor(m => m.DateFin, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        @Html.ValidationMessageFor(m => m.DateFin, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.PEMVise)
        @Html.TextBoxFor(m => m.PEMVise, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.PEMVise, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        <div class="checkbox"><label>@Html.CheckBoxFor(m => m.EstActive) Active</label></div>
        @Html.ValidationMessageFor(m => m.EstActive, "", new { @class = "text-danger" })
    </div>
</div>