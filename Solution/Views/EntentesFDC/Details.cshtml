@model Solution.ViewModels.EntentesFDC.EntenteFDCDetailsViewModel

@{
    ViewBag.Title = "Détails de l'entente FDC";
}

<div class="page-header-custom">
    <div class="row">
        <div class="col-md-8">
            <h2>Détails de l'entente FDC</h2>
        </div>
        <div class="col-md-4 text-right" style="margin-top:25px;">
            @Html.ActionLink("Retour à la liste", "Index", null, new { @class = "btn btn-default" })
        </div>
    </div>
</div>

<div class="dashboard-card">
    <table class="table table-bordered table-striped">
        <tr><th style="width:220px;">ID</th><td>@Model.EntenteFDCId</td></tr>
        <tr><th>Médecin</th><td>@Model.MedecinLibelle</td></tr>
        <tr><th>Type entente</th><td>@Model.TypeEntenteFDC</td></tr>
        <tr><th>Date adhésion</th><td>@(Model.DateAdhesion.HasValue ? Model.DateAdhesion.Value.ToString("yyyy-MM-dd") : "")</td></tr>
        <tr><th>Date fin</th><td>@(Model.DateFin.HasValue ? Model.DateFin.Value.ToString("yyyy-MM-dd") : "")</td></tr>
        <tr><th>PEM visé</th><td>@Model.PEMVise</td></tr>
        <tr><th>Active</th><td>@(Model.EstActive ? "Oui" : "Non")</td></tr>
    </table>

    <div class="text-right">
        @if (User.IsInRole("Admin") || User.IsInRole("SuperUtilisateur"))
        {
            <a href="@Url.Action("Edit", new { id = Model.EntenteFDCId })" class="btn btn-warning">
                <i class="fa-solid fa-pen-to-square"></i> Modifier
            </a>
            <a href="@Url.Action("Delete", new { id = Model.EntenteFDCId })" class="btn btn-danger">
                <i class="fa-solid fa-trash"></i> Supprimer
            </a>
        }
        @Html.ActionLink("Retour", "Index", null, new { @class = "btn btn-default" })
    </div>
</div>