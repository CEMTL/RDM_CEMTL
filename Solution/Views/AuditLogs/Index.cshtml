@model Solution.ViewModels.AuditLogs.AuditLogIndexViewModel

@{
    ViewBag.Title = "Journal d'audit";
}

@Html.Partial("~/Views/Shared/_Alerts.cshtml")

<div class="dashboard-card filters-bar">
    @using (Html.BeginForm("Index", "AuditLogs", FormMethod.Get))
    {
        <div class="row" style="margin-bottom:10px;">
            <div class="col-md-3">
                @Html.TextBoxFor(m => m.TableName, new { @class = "form-control", placeholder = "Table..." })
            </div>
            <div class="col-md-2">
                @Html.DropDownListFor(m => m.ActionType, Model.ActionsDisponibles, new { @class = "form-control" })
            </div>
            <div class="col-md-3">
                @Html.TextBoxFor(m => m.Utilisateur, new { @class = "form-control", placeholder = "Utilisateur..." })
            </div>
            <div class="col-md-2">
                @Html.TextBoxFor(m => m.DateDebut, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            </div>
            <div class="col-md-2">
                @Html.TextBoxFor(m => m.DateFin, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
            </div>
        </div>

        <div class="row">
            <div class="col-md-8">
                @Html.TextBoxFor(m => m.Search, new { @class = "form-control", placeholder = "Recherche globale..." })
            </div>
            <div class="col-md-4 text-right">
                <button type="submit" class="btn btn-default">
                    <i class="fa-solid fa-magnifying-glass"></i> Rechercher
                </button>
                <a href="@Url.Action("Index", "AuditLogs")" class="btn btn-default">
                    <i class="fa-solid fa-rotate-left"></i> Réinitialiser
                </a>
            </div>
        </div>
    }
</div>

<div class="dashboard-card">
    <table id="tableAuditLogs" class="table table-bordered table-striped table-hover registre-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Table</th>
                <th>Enregistrement</th>
                <th>Action</th>
                <th>Utilisateur</th>
                <th>Date action</th>
                <th>Adresse IP</th>
                <th>Champs modifiés</th>
                <th style="width:120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                var badgeClass = "label label-default";

                if (item.Action == "INSERT")
                {
                    badgeClass = "label label-success";
                }
                else if (item.Action == "UPDATE")
                {
                    badgeClass = "label label-warning";
                }
                else if (item.Action == "DELETE")
                {
                    badgeClass = "label label-danger";
                }

                <tr>
                    <td>@item.AuditLogId</td>
                    <td>@item.TableName</td>
                    <td>@item.RecordId</td>
                    <td><span class="@badgeClass">@item.Action</span></td>
                    <td>@item.NomUtilisateur</td>
                    <td>@item.DateAction.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@item.AdresseIP</td>
                    <td style="max-width:300px; white-space:normal;">
                        @(string.IsNullOrWhiteSpace(item.ChangedFields)
                            ? "-"
                            : (item.ChangedFields.Length > 180 ? item.ChangedFields.Substring(0, 180) + "..." : item.ChangedFields))
                    </td>
                    <td class="table-actions nowrap">
                        <button type="button"
                                class="btn btn-info btn-sm btn-icon-only js-open-audit-details"
                                data-id="@item.AuditLogId"
                                title="Détails">
                            <i class="fa-solid fa-circle-info"></i>
                        </button>

                        <a href="@Url.Action("Details", new { id = item.AuditLogId })"
                           class="btn btn-default btn-sm btn-icon-only"
                           title="Ouvrir">
                            <i class="fa-solid fa-up-right-from-square"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="auditLogDetailsModal" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" style="width:95%; max-width:1200px;">
        <div class="modal-content" id="auditLogDetailsModalContent">
            <div class="modal-body text-center" style="padding:40px;">
                <i class="fa fa-spinner fa-spin fa-2x"></i>
                <div>Chargement...</div>
            </div>
        </div>
    </div>
</div>

@section Styles{
    <style>
        .audit-pre {
            white-space: pre-wrap;
            word-break: break-word;
            background: #f8f9fb;
            border: 1px solid #e1e5ea;
            border-radius: 8px;
            padding: 12px;
            max-height: 320px;
            overflow: auto;
        }
    </style>
}

@section Scripts{
    <script>
        $(function () {
            var table = $("#tableAuditLogs");

            if ($.fn.DataTable.isDataTable(table)) {
                table.DataTable().destroy();
            }

            table.DataTable({
                pageLength: 10,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                paging: true,
                ordering: true,
                searching: true,
                info: true,
                autoWidth: false,
                order: [[5, "desc"]],
                language: {
                    processing: "Traitement en cours...",
                    search: "Recherche rapide :",
                    lengthMenu: "Afficher _MENU_ éléments",
                    info: "Affichage de l'élément _START_ à _END_ sur _TOTAL_ éléments",
                    infoEmpty: "Affichage de l'élément 0 à 0 sur 0 élément",
                    infoFiltered: "(filtré de _MAX_ éléments au total)",
                    loadingRecords: "Chargement en cours...",
                    zeroRecords: "Aucun élément à afficher",
                    emptyTable: "Aucune donnée disponible dans le tableau",
                    paginate: {
                        first: "Premier",
                        previous: "Précédent",
                        next: "Suivant",
                        last: "Dernier"
                    }
                },
                columnDefs: [
                    { orderable: false, searchable: false, targets: 8 }
                ]
            });

            $(document).off("click", ".js-open-audit-details").on("click", ".js-open-audit-details", function () {
                var id = $(this).data("id");
                var url = '@Url.Action("DetailsModal", "AuditLogs")' + '?id=' + id;

                $("#auditLogDetailsModal").modal("show");
                $("#auditLogDetailsModalContent").html(
                    '<div class="modal-body text-center" style="padding:40px;">' +
                    '<i class="fa fa-spinner fa-spin fa-2x"></i>' +
                    '<div>Chargement...</div>' +
                    '</div>'
                );

                $("#auditLogDetailsModalContent").load(url);
            });
        });
    </script>
}
