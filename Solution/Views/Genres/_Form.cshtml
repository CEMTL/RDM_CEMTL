@model Solution.ViewModels.Genres.GenreFormViewModel

<div class="dashboard-card">
    <div class="form-group">
        @Html.LabelFor(m => m.CodeGenre)
        @Html.TextBoxFor(m => m.CodeGenre, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.CodeGenre, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Libelle)
        @Html.TextBoxFor(m => m.Libelle, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Libelle, "", new { @class = "text-danger" })
    </div>
</div>
