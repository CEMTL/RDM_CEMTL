@model Solution.ViewModels.Nominations.NominationAdministrativeFormViewModel

@{
    ViewBag.Title = "Modifier la nomination administrative";
}

<div class="page-header-custom">
    <h2>Modifier la nomination administrative</h2>
</div>

@using (Html.BeginForm("Edit", "NominationsAdministratives", new { id = Model.NominationAdministrativeId }, FormMethod.Post, null))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.NominationAdministrativeId)
    @Html.ValidationSummary(true, "Veuillez corriger les erreurs.", new { @class = "alert alert-danger" })

    @Html.Partial("_Form", Model)

    <div class="dashboard-card">
        <button type="submit" class="btn btn-success">Enregistrer</button>
        @Html.ActionLink("Retour", "Index", null, new { @class = "btn btn-default" })
    </div>
}

@section Scripts {
    @Html.Partial("_ValidationScriptsPartial")
}