@model IEnumerable<Solution.ViewModels.Medecins.MedecinCoordonneesIndexItemViewModel>

@{
    ViewBag.Title = "Coordonnées des médecins";
    var actifsSeulement = ViewBag.ActifsSeulement != null && (bool)ViewBag.ActifsSeulement;
    var canManage = ViewBag.CanManage != null && (bool)ViewBag.CanManage;
}

@section Styles{
    <style>
        .dataTables_wrapper .dataTables_paginate {
            position: relative !important;
            z-index: 20 !important;
        }

        .dataTables_wrapper .pagination {
            position: relative !important;
            z-index: 21 !important;
            margin: 0 !important;
        }

            .dataTables_wrapper .pagination > li > a,
            .dataTables_wrapper .pagination > li > span {
                position: relative !important;
                z-index: 22 !important;
                pointer-events: auto !important;
                cursor: pointer !important;
            }
    </style>
}

<div class="page-header-custom">
    <h2>Coordonnées des médecins</h2>
</div>

@Html.Partial("~/Views/Shared/_Alerts.cshtml")

<div class="dashboard-card filters-bar">
    @using (Html.BeginForm("Index", "MedecinCoordonnees", FormMethod.Get))
    {
        <div class="row">
            <div class="col-md-5">
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Recherche par nom, prénom, permis ou NAM..." />
            </div>

            <div class="col-md-3">
                <label class="checkbox-inline" style="margin-top:7px;">
                    <input type="checkbox"
                           name="actifsSeulement"
                           value="true"
                           @(actifsSeulement ? "checked=\"checked\"" : "") />
                    Actifs seulement
                </label>
            </div>

            <div class="col-md-4 text-right">
                <button type="submit" class="btn btn-default">
                    <i class="fa-solid fa-magnifying-glass"></i> Rechercher
                </button>
                <a href="@Url.Action("Index", "MedecinCoordonnees")" class="btn btn-default">
                    <i class="fa-solid fa-rotate-left"></i> Réinitialiser
                </a>
            </div>
        </div>
    }
</div>

<div class="dashboard-card">
    <table id="tableMedecinCoordonnees" class="table table-bordered table-striped table-hover registre-table">
        <thead>
            <tr>
                <th>Permis</th>
                <th>Médecin</th>
                <th>Adresses</th>
                <th>Téléphones</th>
                <th>Courriels</th>
                <th>Installations</th>
                <th>Unités</th>
                <th>Actif</th>
                <th class="nowrap" style="width:120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Permis</td>
                    <td>@item.NomComplet</td>
                    <td>@item.NbAdresses</td>
                    <td>@item.NbTelephones</td>
                    <td>@item.NbCourriels</td>
                    <td>@item.NbInstallations</td>
                    <td>@item.NbUnites</td>
                    <td>@(item.EstActif ? "Oui" : "Non")</td>
                    <td class="table-actions nowrap">
                        <a href="@Url.Action("Manage", new { id = item.MedecinId })"
                           class="btn btn-info btn-sm"
                           title="Gérer">
                            <i class="fa-solid fa-pen-to-square"></i> Gérer
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts{
    <script>
        $(function () {
            var table = $("#tableMedecinCoordonnees");

            if ($.fn.DataTable.isDataTable(table)) {
                table.DataTable().destroy();
            }

            table.DataTable({
                pageLength: 10,
                lengthMenu: [[5, 10, 25, 50, 100], [5, 10, 25, 50, 100]],
                paging: true,
                ordering: true,
                searching: true,
                info: true,
                autoWidth: false,
                order: [[1, "asc"]],
                language: {
                    processing: "Traitement en cours...",
                    search: "Recherche rapide :",
                    lengthMenu: "Afficher _MENU_ éléments",
                    info: "Affichage de l'élément _START_ à _END_ sur _TOTAL_ éléments",
                    infoEmpty: "Affichage de l'élément 0 à 0 sur 0 élément",
                    infoFiltered: "(filtré de _MAX_ éléments au total)",
                    loadingRecords: "Chargement en cours...",
                    zeroRecords: "Aucun élément à afficher",
                    emptyTable: "Aucune donnée disponible dans le tableau",
                    paginate: {
                        first: "Premier",
                        previous: "Précédent",
                        next: "Suivant",
                        last: "Dernier"
                    }
                },
                columnDefs: [
                    { orderable: false, searchable: false, targets: 8 }
                ]
            });
        });
    </script>
}