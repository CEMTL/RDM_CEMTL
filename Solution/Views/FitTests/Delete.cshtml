@model Solution.ViewModels.FitTests.FitTestDetailsViewModel

@{
    ViewBag.Title = "Supprimer un fit test";
}

<div class="page-header-custom">
    <div class="row">
        <div class="col-md-8">
            <h2>Supprimer un fit test</h2>
        </div>
        <div class="col-md-4 text-right" style="margin-top:25px;">
            @Html.ActionLink("Retour à la liste", "Index", null, new { @class = "btn btn-default" })
        </div>
    </div>
</div>

<div class="dashboard-card">
    <div class="alert alert-danger">
        <strong>Attention :</strong> cette action supprimera définitivement ce fit test.
    </div>

    <table class="table table-bordered table-striped">
        <tr><th style="width:220px;">ID</th><td>@Model.FitTestId</td></tr>
        <tr><th>Médecin</th><td>@Model.MedecinLibelle</td></tr>
        <tr><th>Résultat</th><td>@Model.Resultat</td></tr>
        <tr><th>Date fit test</th><td>@(Model.DateFitTest.HasValue ? Model.DateFitTest.Value.ToString("yyyy-MM-dd") : "")</td></tr>
        <tr><th>Commentaire</th><td>@Model.Commentaire</td></tr>
        <tr><th>Actif</th><td>@(Model.EstActif ? "Oui" : "Non")</td></tr>
    </table>

    @using (Html.BeginForm("Delete", "FitTests", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.FitTestId)

        <div class="text-right">
            @Html.ActionLink("Annuler", "Index", null, new { @class = "btn btn-default" })
            <button type="submit" class="btn btn-danger">
                <i class="fa-solid fa-trash"></i> Confirmer la suppression
            </button>
        </div>
    }
</div>