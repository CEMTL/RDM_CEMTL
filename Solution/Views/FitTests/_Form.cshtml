@model Solution.ViewModels.FitTests.FitTestFormViewModel

<div class="dashboard-card">
    <div class="form-group">
        @Html.LabelFor(m => m.MedecinId)
        @Html.DropDownListFor(m => m.MedecinId, Model.MedecinIdOptions, "-- Sélectionner --", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.MedecinId, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Resultat)
        @Html.TextBoxFor(m => m.Resultat, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Resultat, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.DateFitTest)
        @Html.TextBoxFor(m => m.DateFitTest, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        @Html.ValidationMessageFor(m => m.DateFitTest, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.Commentaire)
        @Html.TextAreaFor(m => m.Commentaire, 4, 80, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Commentaire, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        <div class="checkbox"><label>@Html.CheckBoxFor(m => m.EstActif) Actif</label></div>
        @Html.ValidationMessageFor(m => m.EstActif, "", new { @class = "text-danger" })
    </div>
</div>